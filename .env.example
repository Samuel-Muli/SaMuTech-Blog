# Copy this file to .env for local development:  cp .env.example .env
# Never commit your real .env file — it's already in .gitignore.
# In production, set these in your hosting provider's dashboard instead.

# MongoDB connection string.
#   Local MongoDB: mongodb://localhost:27017
#   MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

# Port the Express server listens on. Most hosting providers set this
# automatically — you usually don't need to set it yourself in production.
PORT=8000

# Set automatically to "production" by most hosting providers. Leave unset
# (or "development") for local work.
NODE_ENV=development

# Optional: get an email notification whenever someone subscribes.
# Leave all three unset and subscribers still get saved to the database —
# you just won't be emailed about it.
#
# SMTP_USER/SMTP_PASS are the SENDING account's credentials (any SMTP
# provider works, not just Gmail). For Gmail, SMTP_PASS must be an App
# Password — generate one at https://myaccount.google.com/apppasswords
# (this requires 2-Step Verification to be enabled on that Google account).
# Do NOT use your normal Gmail password here.
SMTP_USER=
SMTP_PASS=
# Who receives the notification. Defaults to samumutua93@gmail.com if unset.
NOTIFY_EMAIL=samumutua93@gmail.com
