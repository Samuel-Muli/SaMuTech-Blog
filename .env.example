# Copy this file to .env for local development:  cp .env.example .env
# Never commit your real .env file — it's already in .gitignore.
# In production, set these in your hosting provider's dashboard instead.

# MongoDB connection string.
#   Local MongoDB: mongodb://localhost:27017
#   MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

# Port the Express server listens on. Most hosting providers set this
# automatically — you usually don't need to set it yourself in production.
PORT=8000

# Set automatically to "production" by most hosting providers. Leave unset
# (or "development") for local work.
NODE_ENV=development
